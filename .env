# .env file for Load Test Client

# Server port cho Express app
PORT=3000

# ==========================================
# CẤU HÌNH BOT CƠ BẢN
# ==========================================
ROOM_NAME=mvm
CLIENT_COUNT=3
BOT_START_INDEX=1
JITSI_DOMAIN=meeting.maivanmanh.online
BOT_NAME_PATTERN=Bot-

# Role của Bot (sender | receiver | both)
# - Nếu là "sender": 1 Bot đại diện là "both", mọi Bot còn lại là "sender".
# - Nếu là "receiver": 1 Bot đại diện là "both", mọi Bot còn lại là "receiver".
# - Nếu là "both": 100% các Bot đều là "both".
BOT_ROLE=receiver

# Giới hạn số lượng Video mà luồng receiver tải xuống khi KHÔNG có ai Share Screen
# (0 = nhận tất cả không giới hạn. Mặc định là 9)
LAST_N_NORMAL=9

# Giới hạn số lượng Video khi có người Share Screen (vì màn hình chứa ít video hơn)
LAST_N_SHARING=3

# Kích hoạt 1 Bot phát thêm màn hình (Screen Share)
ENABLE_SCREEN_SHARE=true

# Nếu = true, chỉ mở HTTP Server tĩnh, KHÔNG chạy Load Test tự động
SERVER_ONLY=false

# ==========================================
# CẤU HÌNH TRÌNH DUYỆT (PLAYWRIGHT)
# ==========================================
HEADLESS=true
BROWSER_STRATEGY=multi-browser
BOTS_PER_BROWSER=5

# Khoảng thời gian nghỉ (Delay) khi khởi tạo
BROWSER_GROUP_DELAY_MS=2000
RAMP_DELAY_MS=1000

DISABLE_GPU=true

# Đường dẫn Media giả lập
FAKE_VIDEO=media/fake-video-720p-15fps.y4m
FAKE_AUDIO=media/fake-audio-noise-5s.wav

# ==========================================
# CẤU HÌNH ĐO LƯỜNG & BENCHMARK
# ==========================================
RUN_ID=run-local-test
LOAD_GENERATOR_ID=lg-1

# Thời gian chờ hệ thống đàm phán ICE và ổn định mạng (giây)
WARMUP_SECONDS=20

# Thời gian CỬA SỔ ĐO LƯỜNG chính thức (giây) - (Bắt buộc >= 30s)
MEASUREMENT_SECONDS=30

# Chu kỳ lấy mẫu WebRTC Stats (mili-giây)
STATS_INTERVAL_MS=2000

# Thời gian chờ để dọn dẹp trình duyệt trước khi tắt
TEARDOWN_DELAY_SECONDS=5

# Thông tin Metadata của máy chạy Load Test
INSTANCE_TYPE=local-mac
AWS_AZ=local
OUTPUT_DIR=./results

# ==========================================
# DEBUGGING
# ==========================================
# Hiển thị bảng Debug UI trên giao diện HTML
DEBUG_STATS=false

# In log DUMP toàn bộ WebRTC RTP Reports ra Terminal ở giây đầu tiên (Chỉ dùng khi lỗi)
DUMP_RAW_WEBRTC_STATS=false
